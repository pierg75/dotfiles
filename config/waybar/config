{
    "layer": "top",
    "position": "bottom",
    "exclusive": true,
    "mode": "hide",
    "spacing": 0,
    "height": 35,
    "ipc": true,
    "passtrough": false,
    "gtk-layer-shell": true,
    "output": ["eDP-1", "DP-8"],
    "tooltip": true,
    "tooltip-format": "{name}",
	"modules-left": [
		"sway/workspaces",
        "sway/mode",
        "sway/window",
	],
	"modules-center": [
		"clock",
	],
	"modules-right": [
		"pulseaudio",
		"memory",
		"cpu",
		"temperature",
		"battery",
		"disk",
        "disk#home",
        "custom/vpn",
        "network",
		"tray"
	],
	"sway/workspaces": {
		"disable-scroll": true,
        "all-outputs": true,
		"format": "{icon}",
        "persistent_workspaces": {
         	"1": [],
         	"2": [],
         	"3": []
        },
        "format-icons": {
            "1": "ϊ╕Α",
            "2": "ϊ║Ν",
            "3": "ϊ╕Κ",
            "4": "ίδδ",
            "focused": "ΎΗΤ",
            "urgent": "ΎΒς",
            "default": "ΎΕΣ"
        },
        "icon-size": 15
	},
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/window": {
	    "format": "{}",
	    "max-length": 70,
	    "rewrite": {
		    "(.*) - Qutebrowser": "ΏθΝΟ Qute $1",
		    "(.*) - Firefox": "ΏθΝΟ Firefox $1",
		    "(.*):zsh (.*)": "zsh > ",
		    "(.*)vim (.*)": "έβψ nvim > ",
		    "(.*)mutt (.*)": "ΏθΥπ mutt > "
	    }
    },
    "tray": {
        "icon-size": 13,
        "spacing": 10
    },
    "clock": {
        "format": "<span color='#bf616a'>ΎΑΩ </span>{:%I:%M %p}",
        "format-alt": "<span color='#bf616a'>ΎΒ│ </span>{:%a %b %d}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "ΎΑξ ΎΛΦ {volume}%",
        "format-bluetooth-muted": "ΎΑο ΎΛΦ",
        "format-muted": "ΎΑο",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol",
    },
    "temperature": {
        "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 60,
        "format-critical": "{icon} {temperatureC}┬░C",
        "format": "{icon} {temperatureC}┬░C",
        "interval": 60,
        "format-icons": ["Ύζτ", "ΎΜΚ", "Ύζσ"]
    },
    "memory": {
        "interval": 30,
        "format": "≤░Ξδ {}%",
        "format-alt":"ΎΣ▓ {used:0.1f}G",
        "max-length": 10,
    },
    "cpu": {
      "interval": 10,
      "format": "ΎΜδ {}%",
      "max-length": 10,
    },
    "battery": {
      "bat": "BAT0",
      "adapter": "ADP0",
      "interval": 60,
      "states": {
          "warning": 30,
          "critical": 15
      },
      "max-length": 20,
      "format": "{icon} {capacity}%",
      "format-warning": "{icon} {capacity}%",
      "format-critical": "{icon} {capacity}%",
      "format-charging": "<span font-family='Font Awesome 6 Free'>ΎΔπ</span> {capacity}%",
      "format-plugged": "ΎΘο  {capacity}%",
      "format-alt": "{icon} {time}",
      "format-full": "ΎΘο  {capacity}%",
      "format-icons": ["ΎΚΕ ", "ΎΚΔ ", "ΎΚΓ ", "ΎΚΒ ", "ΎΚΑ "],
    },
	"disk": {
		"interval": 5,
		"format": "ΏθΨ┤ / {percentage_used:2}%",
		"path": "/"
	},
	"disk#home": {
		"interval": 5,
		"format": "ΏθΨ┤ /home {percentage_used:2}%",
		"path": "/home"
	},
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} ΏθΨπ",
        "format-linked": "{ifname} (No IP) ΏθΨπ",
        "format-disconnected": "Disconnected έγι",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "interval": 60,
        "on-click-middle": "exec termite -e nmtui",
    },
    "custom/vpn": {
        "format": "{icon}",
        "return-type": "json",
        "interval": 30,
        "exec": "$HOME/bin/check_vpn.sh",
        "format-icons": ["ΎΓε","ΎΑμ"]
    },
	 "idle_inhibitor": {
         "format": "{icon}",
         "format-icons": {
         "activated": "ΎεΘ",
         "deactivated": "ΎεΙ"
      }
    }
}
