[user]
	email = pl@whats.com
	name = PL

[core]
    pager = delta
	editor = nvim

[delta]
    side-by-side = true
    line-numbers-left-format = ""
    line-numbers-right-format = "│ "
    features = side-by-side line-numbers decorations    
    syntax-theme = Nord

[interactive]
    diffFilter = delta --color-only


[delta "decorations"]
    commit-decoration-style = bold yellow box ul
    file-style = bold yellow ul
