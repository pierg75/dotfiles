[user]
	email = pl@whats.com
	name = PL

[core]
    pager = delta

[delta]
    plus-color = "#012800"
    minus-color = "#340001"
    #syntax-theme = Monokai Extended
    side-by-side = true
    line-numbers-left-format = ""
    line-numbers-right-format = "│ "
    syntax-theme = Nord

[interactive]
    diffFilter = delta --color-only
